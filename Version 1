function shuffle(a) {
  var b = a.slice();
  for (var i = b.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = b[i]; b[i] = b[j]; b[j] = tmp;
  }
  return b;
}
function genQueue(n) {
  /* Always use standard meals for random queues — themed meals set directly */
  var std = ['hamburger','hotdog','sandwich'];
  return Array.from({length: n}, function() { return std[Math.floor(Math.random() * std.length)]; });
}
function makeRound(rec, nm) {
  nm = nm || 0;
  var ns = {};
  rec.needs.forEach(function(id) { ns[id] = true; });
  var decoys = shuffle(ING.map(function(i) { return i.id; }).filter(function(id) { return !ns[id]; }));
  var nd = Math.max(2, TOTAL_TILES - rec.needs.length - nm);
  /* Fresh required tiles — always clean */
  var freshIds = rec.needs.slice();
  var decoyIds = decoys.slice(0, nd);
  var ids = shuffle(freshIds.concat(decoyIds));
  var ts = Date.now();
  var result = ids.map(function(ingId, i) { return {key:'i'+ts+i, type:'ing', ingId:ingId, spoiled:false}; });
  /* Mold mechanic: Level 6+ — replace 2 decoy slots with moldy required-ingredient dupes */
  if (G.level && G.level.id >= 6 && freshIds.length >= 2) {
    var moldCount = 2;
    var moldTargets = shuffle(freshIds.slice()).slice(0, moldCount);
    var replaced = 0;
    for (var j = result.length - 1; j >= 0 && replaced < moldCount; j--) {
      /* Replace a decoy (not a fresh required tile) */
      if (!ns[result[j].ingId]) {
        result[j] = {key:'mold'+ts+j, type:'ing', ingId:moldTargets[replaced], spoiled:true};
        replaced++;
      }
    }
  }
  for (var i = 0; i < nm; i++) result.push({key:'m'+ts+i, type:'mys', ingId:null, spoiled:false});
  return shuffle(result);
}


