function updateTimerDisplay() {
  var el = document.getElementById('timer-val');
  if (!el) return;
  var pct = G.timeLeft / levelTime(G.level.id) * 100;
  var col = pct > 50 ? '#27AE60' : pct > 25 ? '#F39C12' : '#E74C3C';
  el.textContent = G.timeLeft + 's';
  el.style.color = col;
  el.style.animation = pct <= 15 ? 'blinkTimer .5s infinite' : 'none';
  var bar = document.getElementById('timer-bar');
  if (bar) { bar.style.width = Math.max(0, pct) + '%'; bar.style.background = col; }
}

function renderGame() {
  if (!G.recipe) return;
  var gs = document.getElementById('gamescreen');
  var rec = G.recipe, lv = G.level;
  var pct = Math.max(0, G.timeLeft / levelTime(lv.id) * 100);
  var tCol = pct > 50 ? '#27AE60' : pct > 25 ? '#F39C12' : '#E74C3C';
  var nextId = rec.needs[G.seqIdx];

  /* Queue bar */
  /* Kitchen Ticket Queue — grouped meal counts, live decrement */
  var _qtotal = {}, _qdone = {};
  for (var _qi = 0; _qi < G.mealQ.length; _qi++) {
    _qtotal[G.mealQ[_qi]] = (_qtotal[G.mealQ[_qi]] || 0) + 1;
    if (G.mealStatus[_qi] === 'done')
