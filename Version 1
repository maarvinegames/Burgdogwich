function _afterAuth() {
  bgmPlay(); /* user just tapped Login/Sign Up */
  hideAuth();
  loadProgress();
  var next=window._authNext; window._authNext=null;
  if(next==='play'){ renderLevelSelect(); showScreen('levelselect'); }
  else if(next==='profile'){ showProf(); }
  else {
    showScreen('welcome');
