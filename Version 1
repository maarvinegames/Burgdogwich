function useBooster(id) {
  if (G.phase !== 'playing') return;
  if (id === 'extraShift') {
    if (Economy.extraShift <= 0) return;
    Economy.extraShift--;
    Economy._save();
    G.timeLeft += 5;
    renderGame();
  } else if (id === 'instantClear') {
    if (Economy.diamonds < 2) {
      if (typeof storeToast === 'function') storeToast('Need 2 \uD83D\uDC8E Diamonds!','rgba(200,30,30,.9)');
      return;
    }
    Economy.diamonds -= 2;
    Economy._save();
    Economy._ui();
    /* Complete entire current meal instantly */
    G.seqIdx = G.recipe ? G.recipe.needs.length : 0;
    /* Reset timer — fresh time for the next meal */
    G.timeLeft = levelTime(G.level.id);
    if (typeof SFX !== 'undefined') SFX.level();
    advanceMeal();
  } else if (id === 'shield') {
    /* Shield auto-activates on next mistake — just show status */
    if (G.shields <= 0) return;
    /* Flash to confirm shield is active */
    var fl=document.createElement('div');
    fl.style.cssText='position:fixed;inset:0;background:rgba(93,173,226,.25);z-index:999;pointer-events:none';
    fl.style.animation='shieldFlash .4s ease-out forwards';
