function boosterRowHTML() {
  var slots = [
    { id:'extraShift', icon:'\u23F0', label:'+5s',    count:Economy.extraShift },
    { id:'instantClear', icon:'\uD83D\uDC8E', label:'Instant', count:Economy.diamonds, minCount:2, costHint:'2\uD83D\uDC8E' },
    { id:'shield',     icon:'\uD83D\uDEE1\uFE0F', label:'Shield',  count:G.shields         }
  ];
  var html = '';
