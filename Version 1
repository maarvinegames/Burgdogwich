/* ═════════════════════════════════════════════════════════════
   ECONOMY ENGINE — coins + hearts, persisted to localStorage
═════════════════════════════════════════════════════════════ */
var Economy = {
  coins: 100, hearts: 5, shields: 0, diamonds: 0, extraShift: 0, prepChef: 0, extraHearts: 0, _max: 5, _k: 'bdw_eco_v1',
  init: function() {
    try {
      var d = JSON.parse(localStorage.getItem(this._k));
      if (d) { this.coins=d.coins||100; this.hearts=Math.min(5,d.hearts||5); this.shields=d.shields||0; this.diamonds=d.diamonds||0; this.extraShift=d.extraShift||0; this.extraHearts=d.extraHearts||0; this.extraHearts=d.extraHearts||0; this.prepChef=d.prepChef||0; }
    } catch(e) {}
    this._ui();
  },
  _save: function() {
    try { localStorage.setItem(this._k,JSON.stringify({coins:this.coins,hearts:this.hearts,shields:this.shields,diamonds:this.diamonds,extraShift:this.extraShift,prepChef:this.prepChef,extraHearts:this.extraHearts||0})); } catch(e) {}
    this._ui();
  },
  _ui: function() {
    var c=document.querySelectorAll('[data-econ="coins"]'),hh=document.querySelectorAll('[data-econ="hearts"]'),dd=document.querySelectorAll('[data-econ="diamonds"]');
    for(var i=0;i<c.length;i++) c[i].textContent=this.coins;
    for(var i=0;i<hh.length;i++) hh[i].textContent=this.hearts;
    for(var i=0;i<dd.length;i++) dd[i].textContent=this.diamonds;
    if(typeof HS!=='undefined'){HS.count=this.hearts;if(typeof updHB==='function')updHB();}
  },
  addCoins: function(n){this.coins+=Math.max(0,n|0);this._save();},
  spendCoins: function(n){if(this.coins<n)return false;this.coins-=n;this._save();return true;},
  spendDiamonds: function(n){if(this.diamonds<n)return false;this.diamonds-=n;this._save();return true;},
  loseHeart: function(){
    var wasMax=(this.hearts>=5);
    this.hearts=Math.max(0,this.hearts-1);
    if(typeof HS!=='undefined'){
      HS.count=Math.min(5,this.hearts);
      /* Lock in absolute next-heart timestamp the moment hearts first drop below max */
      if(wasMax&&this.hearts<5){
        var nts=Date.now()+(30*60*1000);
        HS.lostAt=Date.now();
        try{localStorage.setItem('bdw_next_heart_ts',nts.toString());}catch(e){}
      }
    }
    this._save();
  },
  addHearts: function(n){
    var space=Math.max(0,5-this.hearts);
    var fills=Math.min(n||1,space);
    var overflow=(n||1)-fills;
    this.hearts=this.hearts+fills;
    this.extraHearts=(this.extraHearts||0)+overflow;
    if(typeof HS!=='undefined'){
      HS.count=this.hearts;
      if(this.hearts>=5){
        HS.lostAt=null;
        /* Tank full — kill the refill countdown */
        try{localStorage.removeItem('bdw_next_heart_ts');}catch(e){}
      }
    }
    this._save();
  }
};

/* ═════════════════════════════════════════════════════════════
   HEART REFILL SYSTEM (Candy Crush style)
═════════════════════════════════════════════════════════════ */
var HS={count:5,max:5,refillMs:30*60*1000,lostAt:null,unlimUntil:null};
function hasUL(){
  try{
    var ts=parseInt(localStorage.getItem('bdw_unlim_ts')||'0');
    if(ts>0&&ts>Date.now()){HS.unlimUntil=ts;return true;}
  }catch(e){}
  HS.unlimUntil=null;return false;
}
function canPlay(){return hasUL()||Economy.hearts>0;}
function loseHeart(){if(hasUL())return;Economy.loseHeart();}
function addHearts(n){Economy.addHearts(n||1);}
function syncH(){
  if(hasUL()||Economy.hearts>=5)return;
  try{
    var nextTs=parseInt(localStorage.getItem('bdw_next_heart_ts')||'0');
    if(!nextTs||Date.now()<nextTs)return;
    /* One or more hearts earned — catch up */
    var refMs=30*60*1000;
    var overdue=Date.now()-nextTs;
    var earned=1+Math.floor(overdue/refMs);
    Economy.hearts=Math.min(5,Economy.hearts+earned);
    HS.count=Economy.hearts;
    if(Economy.hearts>=5){
      HS.lostAt=null;
      localStorage.removeItem('bdw_next_heart_ts');
    } else {
      /* Partial chunk remaining — schedule next heart */
      var partial=overdue%refMs;
      var newNext=Date.now()+(refMs-partial);
      localStorage.setItem('bdw_next_heart_ts',newNext.toString());
      HS.lostAt=newNext-refMs;
    }
    Economy._save();
  }catch(e){}
}
function nextHMs(){
  if(Economy.hearts>=5)return 0;
  try{
    var ts=parseInt(localStorage.getItem('bdw_next_heart_ts')||'0');
    if(!ts)return 0;
    var rem=ts-Date.now();
    return rem>0?rem:0;
  }catch(e){return 0;}
}
function fmtMs(ms){if(ms<=0)return'0:00';var s=Math.ceil(ms/1000),h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sc=s%60;if(h>0)return h+':'+String(m).padStart(2,'0')+':'+String(sc).padStart(2,'0');return m+':'+String(sc).padStart(2,'0');}

/* Buy 1 Heart for 100 Coins from the Out of Hearts modal */
function buyHeartWithCoins() {
  var errEl = document.getElementById('nhm-coin-err');
  var btn   = document.getElementById('buy-heart-coin-btn');
  if (errEl) errEl.style.display = 'none';
  /* Step 1: check balance */
  if (Economy.coins < 100) {
    if (errEl) errEl.style.display = 'block';
    if (btn) {
      btn.classList.remove('insuff'); void btn.offsetWidth;
      btn.classList.add('insuff');
      setTimeout(function(){ btn.classList.remove('insuff'); }, 600);
    }
    return;
  }
  /* Steps 2-4: deduct, add heart, save, update UI, close */
  Economy.coins  -= 100;
  Economy.hearts  = Math.min(Economy._max, Economy.hearts + 1);
  if (typeof HS !== 'undefined') {
    HS.count = Economy.hearts;
    if (Economy.hearts >= Economy._max) HS.lostAt = null;
  }
  Economy._save();
  if (typeof updHB === 'function') updHB();
  Economy._ui();
  closeNH();
}
function buyHR(){
  if(Economy.spendDiamonds(1)){Economy.addHearts(5);closeNH();updHB();}
  else{if(typeof storeToast==='function')storeToast('Need 1 \uD83D\uDC8E Diamond!','rgba(200,30,30,.9)');}
}

/* ═══════════════════════════════════════════════════════════════
   TIMESTAMP ENGINE — syncSystemClockWithGameplay()
   Runs once at boot. Compares device clock (Date.now()) against
   all saved absolute timestamps so the game stays correct even
   if the app was closed for hours or days.
═══════════════════════════════════════════════════════════════ */
function syncSystemClockWithGameplay(){
  var now=Date.now();
  var refMs=30*60*1000;

  try{
    /* ── Unlimited Pass: restore or expire from device clock ─── */
    var unlimTs=parseInt(localStorage.getItem('bdw_unlim_ts')||'0');
    if(unlimTs>0){
      if(now<unlimTs){
        HS.unlimUntil=unlimTs;  /* Pass still active */
      } else {
        HS.unlimUntil=null;
        localStorage.removeItem('bdw_unlim_ts');  /* Expired while closed */
      }
    }

    /* ── Heart Refill: award hearts earned while app was closed ─ */
    if(Economy.hearts<5&&!hasUL()){
      var nextTs=parseInt(localStorage.getItem('bdw_next_heart_ts')||'0');
      if(nextTs>0){
        if(now>=nextTs){
          /* Calculate full hearts earned during offline time */
          var overdue=now-nextTs;
          var earned=1+Math.floor(overdue/refMs);
          Economy.hearts=Math.min(5,Economy.hearts+earned);
          HS.count=Economy.hearts;

          if(Economy.hearts>=5){
            /* Tank full — no countdown needed */
            HS.lostAt=null;
            localStorage.removeItem('bdw_next_heart_ts');
          } else {
            /* Still not full — resume partial countdown for next heart */
            var partial=overdue%refMs;
            var resumeTs=now+(refMs-partial);
            localStorage.setItem('bdw_next_heart_ts',resumeTs.toString());
            HS.lostAt=resumeTs-refMs;
          }
        } else {
          /* Timestamp is in the future — resume countdown from correct position */
          HS.lostAt=nextTs-refMs;
          HS.count=Economy.hearts;
        }
        Economy._save();
      }
    }
  }catch(e){
    console.warn('syncSystemClockWithGameplay error:',e);
  }
}
function buyUL(mins,cost){
  if(!Economy.spendDiamonds(cost)){
    if(typeof storeToast==='function')storeToast('Need more \uD83D\uDC8E Diamonds!','rgba(200,30,30,.9)');
    return;
  }
  /* Lock absolute expiry to device clock so it survives app close */
  var expiryTs=Date.now()+(mins*60*1000);
  HS.unlimUntil=expiryTs;
  try{localStorage.setItem('bdw_unlim_ts',expiryTs.toString());}catch(e){}
  Economy.addHearts(5);
  closeNH();updHB();
}
function showNH(){
  refNH(); Economy._ui();
  var btn=document.getElementById('buy-heart-coin-btn');
  if(btn) btn.disabled=(Economy.hearts>=5);
  var er=document.getElementById('nhm-coin-err');
  if(er) er.style.display='none';
  document.getElementById('nhm').classList.add('open');
}
function closeNH(){document.getElementById('nhm').classList.remove('open');}
function refNH(){
  var r=document.getElementById('nhhr');
  if(r){r.innerHTML='';for(var i=0;i<5;i++){var s=document.createElement('span');s.className='nhh'+(i>=HS.count&&!hasUL()?' e':'');s.textContent='\u2764\uFE0F';r.appendChild(s);}}
  var ms=nextHMs();
  var cd=document.getElementById('nhcd'),wb=document.getElementById('nhwb'),ti=document.getElementById('nht');
  if(hasUL()&&ti){ti.textContent='Unlimited Lives active!';}
  else if(cd){cd.textContent=ms>0?fmtMs(ms):'Ready!';}
  if(wb)wb.textContent=ms>0?('Wait \u2014 next heart in '+fmtMs(ms)):'Close';
}
function updHB(){
  var he=document.getElementById('hsh'),ce=document.getElementById('hs-count'),te=document.getElementById('hs-time');
  if(!he)return;
  var s='';for(var i=0;i<5;i++)s+='<span class="hsh'+(hasUL()||i<HS.count?'':' empty')+'">\u2764\uFE0F</span>';
  he.innerHTML=s;
  if(hasUL()){if(ce)ce.innerHTML='\u26A1 Unlimited Lives <span class="ubadge">'+fmtMs(HS.unlimUntil-Date.now())+'</span>';if(te)te.textContent='';}
  else if(HS.count>=5){if(ce)ce.textContent='5 / 5  Full!';if(te)te.textContent='';}
  else{if(ce)ce.textContent=HS.count+' / 5 hearts';var ms=nextHMs();if(te)te.textContent=ms>0?('Next heart in '+fmtMs(ms)):'Refilling...';}
}
setInterval(function(){syncH();updHB();if(document.getElementById('nhm')&&document.getElementById('nhm').classList.contains('open'))refNH();},1000);

/* ═════════════════════════════════════════════════════════════
   PROFILE
═════════════════════════════════════════════════════════════ */
var PROF = {
  purchasedH:      0,
  dailyAt:         null,
  accountCreated:  null,   /* ISO timestamp — set once on first ever boot */
  _k: 'bdw_prof_v1',

  /* Load saved profile from localStorage */
  init: function() {
    try {
      var d = JSON.parse(localStorage.getItem(this._k));
      if (d) {
        this.purchasedH     = d.purchasedH     || 0;
        this.dailyAt        = d.dailyAt        || null;
        this.accountCreated = d.accountCreated || null;
      }
    } catch(e) {}
    /* First-ever boot: lock in account creation date and never overwrite */
    if (!this.accountCreated) {
      this.accountCreated = new Date().toISOString();
      this._save();
    }
  },

  /* Persist all profile fields to localStorage */
  _save: function() {
    try {
      localStorage.setItem(this._k, JSON.stringify({
        purchasedH:     this.purchasedH,
        dailyAt:        this.dailyAt,
        accountCreated: this.accountCreated
      }));
    } catch(e) {}
  }
};
