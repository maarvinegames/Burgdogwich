  }
}
function processAuthFlow() {
  var email=(document.getElementById('auth-email').value||'').trim().toLowerCase();
  var pwd=document.getElementById('auth-password').value||'';
  var mode=(document.getElementById('auth-submit').dataset.mode||'login');
  if(!email||!pwd){setAuthError('Please enter email and password.');return;}
  if(email.indexOf('@')<0||email.indexOf('.')<0){setAuthError('Enter a valid email address.');return;}
  if(pwd.length<6){setAuthError('Password must be at least 6 characters.');return;}
  var dir=_loadDir(), uid=hashPwd(email), pwdH=hashPwd(pwd);
  if(mode==='login'){
    var rec=dir[uid];
    if(!rec){setAuthError('No account found. Try Sign Up.');return;}
    if(rec.pwdHash!==pwdH){setAuthError('Incorrect password.');return;}
    setCurrentUser({id:uid,email:email,isGuest:false,dataKey:uid});
    if(!loadUserData(uid))initUserData();
    _afterAuth();
  } else {
    if(dir[uid]){setAuthError('Account already exists. Try Login.');return;}
    dir[uid]={uid:uid,email:email,pwdHash:pwdH,accountCreated:new Date().toISOString()};
    _saveDir(dir);
    setCurrentUser({id:uid,email:email,isGuest:false,dataKey:uid});
    initUserData();
    if(window._pendingLinkBonus){Economy.shields++;Economy._save();window._pendingLinkBonus=false;}
    saveUserData(uid);
    _afterAuth();
  }
}
