/* ══════════════════════════════════════════════════════════════
   PAUSE SYSTEM  —  handles both player tap and OS interrupts
   ══════════════════════════════════════════════════════════════ */
function pauseGame() {
  if (G.phase !== 'playing') return; /* only pause during active play */
  /* 1. Freeze timer */
  clearInterval(G._timer);
  /* 2. Mark phase */
  G.phase = 'paused';
  /* 3. Suspend audio context + pause BGM */
  try { if (_actx) _actx.suspend(); } catch(e) {}
  bgmPause();
  /* 4. Save Economy state in case OS kills the app */
  try { Economy._save(); } catch(e) {}
  /* 5. Show overlay with time remaining */
  var ov = document.getElementById('pause-overlay');
  var tl = document.getElementById('pause-time-left');
  if (tl) tl.textContent = '⏱ ' + G.timeLeft + ' second' + (G.timeLeft !== 1 ? 's' : '') + ' left';
  if (ov) ov.classList.add('active');
}

function resumeGame() {
  if (G.phase !== 'paused') return;
  /* 1. Hide overlay */
  var ov = document.getElementById('pause-overlay');
  if (ov) ov.classList.remove('active');
  /* 2. Resume audio context + BGM */
  try { if (_actx) _actx.resume(); } catch(e) {}
  bgmResume();
  /* 3. Restore phase and restart timer */
  G.phase = 'playing';
  G._timer = setInterval(tick, 1000);
}

function quitToMap() {
  /* Clean up game state then go to map */
  clearInterval(G._timer);
  G.phase = 'idle';
  try { if (_actx) _actx.resume(); } catch(e) {}
  var ov = document.getElementById('pause-overlay');
  if (ov) ov.classList.remove('active');
  try { Economy._save(); } catch(e) {}
  renderLevelSelect();
  showScreen('levelselect');
}

