    var isDmd  = s.id === 'instantClear';
    html += '<div class="booster-slot' + (locked ? ' locked' : '') + '"'
          + (locked ? '' : ' data-booster="' + s.id + '"')
          + (isDmd && !locked ? ' style="border-color:#5DADE2"' : '') + '>';
    html += '<span class="booster-icon">' + s.icon + '</span>';
