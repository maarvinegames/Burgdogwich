#flare2{position:absolute;width:22px;height:4px;background:linear-gradient(90deg,rgba(255,255,255,0),rgba(255,255,255,.6),rgba(255,255,255,0));border-radius:50%;animation:flare2 3.5s ease-in-out 1s infinite}
@keyframes glowRing{0%,100%{opacity:.3;transform:translate(-50%,-50%) scale(1)}50%{opacity:.6;transform:translate(-50%,-50%) scale(1.4)}}
#glow-ring{position:absolute;top:50%;left:50%;width:110px;height:110px;border-radius:50%;background:radial-gradient(circle,rgba(255,230,50,.35),transparent 70%);animation:glowRing 2.4s ease-in-out infinite}

/* WELCOME BUTTONS */
#welcome-btns{position:absolute;bottom:22px;left:0;right:0;display:flex;flex-direction:column;align-items:center;gap:9px;z-index:10}
.btn3d{touch-action:manipulation;display:block;width:200px;padding:11px 0;border:none;border-radius:50px;cursor:pointer;font-family:'Arial Black',Arial,sans-serif;font-size:18px;font-weight:900;color:#fff;letter-spacing:.5px;text-shadow:0 1px 3px rgba(0,0,0,.45);background:linear-gradient(180deg,#FFA733 0%,#FF8C00 45%,#D46800 100%);box-shadow:0 6px 0 #9B4D00,0 8px 16px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.35);transition:transform .1s,box-shadow .1s}
.btn3d:active{transform:translateY(4px);box-shadow:0 2px 0 #9B4D00,0 3px 8px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.35)}
#gear-wrap{display:flex;align-items:center}
#gear-btn{background:none;border:none;cursor:pointer;padding:6px;display:flex}
@keyframes gearHover{from{transform:rotate(0)}to{transform:rotate(30deg)}}
#gear-btn:hover svg{animation:gearHover .4s ease forwards}

/* SETTINGS MODAL */
#settings-modal{position:absolute;inset:0;background:rgba(0,0,0,.72);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
#settings-modal.open{opacity:1;pointer-events:all}
.modal-card{background:linear-gradient(155deg,#FF8C00,#C43010);border-radius:22px;padding:22px 20px;width:88%;max-width:310px;border:3px solid rgba(255,255,255,.28);box-shadow:0 24px 60px rgba(0,0,0,.6)}
.modal-title{font-size:20px;font-weight:900;text-align:center;margin-bottom:18px;text-shadow:0 2px 4px rgba(0,0,0,.35)}
.setting-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid rgba(255,255,255,.18)}
.setting-row:last-of-type{border:none}
.setting-label{font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px}
.toggle{width:50px;height:27px;border-radius:14px;background:#555;position:relative;cursor:pointer;transition:background .3s;flex-shrink:0;border:2px solid rgba(255,255,255,.15)}
.toggle.on{background:#27AE60} /* ON = green, knob RIGHT */
.toggle::after{content:'';position:absolute;top:2px;left:2px;width:19px;height:19px;border-radius:50%;background:#fff;transition:left .3s;box-shadow:0 2px 4px rgba(0,0,0,.3)}
.toggle.on::after{left:25px} /* ON = knob slides RIGHT */
.howto-panel{background:rgba(0,0,0,.28);border-radius:12px;padding:12px;margin-top:10px;display:none}
.howto-panel.open{display:block}
.howto-text{font-size:12.5px;line-height:1.7;color:rgba(255,255,255,.92)}
.modal-close{margin-top:16px;width:100%;padding:11px;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.35);border-radius:12px;color:#fff;font-size:15px;font-weight:700;cursor:pointer}
.modal-close:hover{background:rgba(255,255,255,.28)}

/* LEVEL SELECT */
#levelselect{background:linear-gradient(180deg,#D43010,#8B1808 55%,#3A0800);display:flex;flex-direction:column;justify-content:flex-start;align-items:stretch;overflow:hidden}
.ls-header{display:flex;align-items:center;gap:10px;padding:13px 15px;background:rgba(0,0,0,.5);border-bottom:2px solid rgba(255,140,0,.22);flex-shrink:0}
.ls-.ls-body{flex:1;padding:14px;overflow-y:auto;-webkit-overflow-scrolling:touch}
.lvl-card{display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.1);border:1px solid rgba(255,140,0,.3);border-radius:13px;padding:11px 13px;margin-bottom:7px;cursor:pointer;transition:background .12s,transform .1s}
.lvl-card:hover:not(.locked){background:rgba(255,255,255,.18);transform:translateX(4px)}
.lvl-card.locked{opacity:.42;cursor:not-allowed}
.lvl-num{width:37px;height:37px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#FF8C00,#D43010);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;border:2px solid #FFD700}
.lvl-num.locked-num{background:rgba(50,50,50,.5);border-color:#555}

/* GAME SCREEN */
#gamescreen{background:linear-gradient(180deg,#D43010,#8B1808 55%,#3A0800);flex-direction:column;justify-content:flex-start;overflow:hidden}

/* GAME OVERLAYS */
.flash-ov{position:absolute;inset:0;background:rgba(220,48,48,.32);pointer-events:none;z-index:50;border-radius:0;animation:flashFade .4s ease forwards}
.burst-ov{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(39,174,96,.92);border-radius:15px;padding:13px 20px;display:flex;align-items:center;gap:11px;z-index:55;pointer-events:none;animation:burstPop .9s ease forwards;white-space:nowrap}
.score-pop{position:absolute;left:50%;font-size:21px;font-weight:700;pointer-events:none;z-index:52;animation:popUp .85s ease forwards;text-shadow:0 2px 8px rgba(0,0,0,.85)}
.myst-toast{position:absolute;top:64px;left:50%;transform:translateX(-50%);padding:9px 20px;border-radius:24px;font-weight:700;font-size:14px;z-index:56;white-space:nowrap;pointer-events:none;border:2px solid rgba(255,255,255,.22);animation:toastIn .35s ease forwards}

/* TILES */
.tile{border-radius:10px;padding:6px 2px 4px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;box-shadow:0 3px 8px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.2);position:relative;transition:opacity .2s,transform .15s}
.tile.done{opacity:.37;transform:scale(.88);cursor:default}
.tile-icon{width:42px;height:42px;display:flex;align-items:center;justify-content:center}
.tile-lbl{font-size:8.5px;font-weight:700;text-align:center;line-height:1.15;max-width:50px;text-shadow:0 1px 3px rgba(0,0,0,.7)}
.chk-slot{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;border:2px solid rgba(255,255,255,.14);opacity:.28;overflow:hidden;transition:all .25s;flex-shrink:0}
.chk-slot.done{background:rgba(39,174,96,.4)!important;border-color:#27AE60!important;opacity:1}
.chk-slot.next{border-color:#FFD700!important;opacity:1}
.chk-lbl{font-size:7px;font-weight:700;text-align:center;max-width:28px;line-height:1.1;color:rgba(255,255,255,.22)}
.chk-lbl.done{color:#7DCEA0}.chk-lbl.next{color:#FFD700}
.mystery-tile{background:linear-gradient(135deg,#2C3E50,#6C2E8A)!important}
.mystery-used{opacity:.38!important;cursor:default!important}

/* KEYFRAMES */
@keyframes flashFade{0%{opacity:.32}100%{opacity:0}}
@keyframes burstPop{0%{transform:translate(-50%,-50%) scale(.3);opacity:0}35%{transform:translate(-50%,-50%) scale(1.1);opacity:1}75%{transform:translate(-50%,-50%) scale(1);opacity:1}100%{transform:translate(-50%,-50%) scale(.85);opacity:0}}
@keyframes popUp{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(-54px)}}
@keyframes toastIn{0%{opacity:0;transform:translateX(-50%) scale(.7)}100%{opacity:1;transform:translateX(-50%) scale(1)}}
@keyframes tileShake{0%,100%{transform:translateX(0)}20%{transform:translateX(-7px)}40%{transform:translateX(7px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}
@keyframes tilePop{0%{transform:scale(1)}30%{transform:scale(1.24)}65%{transform:scale(.93)}100%{transform:scale(1)}}
@keyframes nextGlow{0%,100%{box-shadow:0 0 0 2px #FFD700,0 0 10px rgba(255,215,0,.5)}50%{box-shadow:0 0 0 3px #FFD700,0 0 20px rgba(255,215,0,1)}}
@keyframes mystGlow{0%,100%{box-shadow:0 0 10px rgba(155,89,182,.45)}50%{box-shadow:0 0 22px rgba(155,89,182,.95)}}
@keyframes blinkTimer{0%,100%{opacity:1}50%{opacity:.28}}
