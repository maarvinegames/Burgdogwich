/* Delegate tile clicks */
var _el_gamescreen = document.getElementById('gamescreen');
if (_el_gamescreen) _el_gamescreen.addEventListener('click', function(e) {
  /* Booster buttons — data-booster avoids onclick escaping issues */
  var bsl = e.target.closest('[data-booster]');
  if (bsl) { useBooster(bsl.getAttribute('data-booster')); return; }
  /* Pause button via delegation — survives innerHTML rebuilds */
  if (e.target.closest('.pause-btn')) { pauseGame(); return; }
  /* Back button — works even after innerHTML rebuilds */
  if (e.target.closest('#back-to-ls')) {
    clearInterval(G._timer); clearTimeout(G._conTimer);
    var tut = document.getElementById('tut-overlay');
    if (tut) tut.remove();
    var mtut = document.getElementById('mold-tut-overlay');
    if (mtut) mtut.remove();
    G.phase = 'idle';
    renderLevelSelect();
    showScreen('levelselect');
    return;
  }
  /* Extra heart tap */
  if (e.target.closest('[data-action="useExtraHeart"]')) { useExtraHeart(); return; }
  /* Moldy tile taps — intercept before normal tile logic */
  var mTile = e.target.closest('[data-status="spoiled"]');
  if (mTile && G.phase === 'playing') { showMoldyPopup(); return; }
  /* Normal tile taps */
  var tile = e.target.closest('[data-key]');
  if (tile && tile.dataset.key) tapTile(tile.dataset.key);
});

