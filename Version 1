/* ══════════════════════════════════════════════════════════════
   INTERSTITIAL ADS  — alternates between 2 ad images
   Replace _showInterstitialAd() with real AdMob calls when native
   ══════════════════════════════════════════════════════════════ */
var _interAds = [
  'data:image/jpeg;base64,',
  'data:image/jpeg;base64,'
];
var _interIdx       = 0;   /* alternates 0 → 1 → 0 → 1 */
var _interCallback  = null;
var _interTimer     = null;
var _interCountdown = null;

function _showInterstitialAd(onDone) {
  /* COPPA: never show ads to under-13 */
  if (typeof isChild !== 'undefined' && isChild) { onDone(); return; }
  /* Only show every 3rd level (3, 6, 9, 12...) */
  if (!G.level || G.level.id % 3 !== 0) { onDone(); return; }

  /* ── AdMob swap-in point ──────────────────────────────────
     Replace everything inside this function with:
       AdMob.prepareInterstitial({ adId:'ca-app-pub-XXXX/XXXX' });
       AdMob.showInterstitial();
       AdMob.addListener('onAdDismiss', onDone);
     ─────────────────────────────────────────────────────── */

  _interCallback = onDone;

  /* Pick alternating image */
  var img = document.getElementById('inter-img');
  if (img) img.src = _interAds[_interIdx % _interAds.length];
  _interIdx++;

  /* Show overlay */
  var ov = document.getElementById('inter-overlay');
  if (ov) ov.classList.add('active');

  /* Reset skip button + timer */
  var skipBtn  = document.getElementById('inter-skip');
  var timerEl  = document.getElementById('inter-timer');
  if (skipBtn)  skipBtn.style.display = 'none';
  if (timerEl)  timerEl.style.display = 'block';

  /* 5-second countdown before skip appears */
  var secs = 5;
  if (timerEl) timerEl.textContent = secs;
  _interCountdown = setInterval(function() {
    secs--;
    if (timerEl) timerEl.textContent = Math.max(0, secs);
    if (secs <= 0) {
      clearInterval(_interCountdown);
      if (skipBtn)  skipBtn.style.display = 'block';
      if (timerEl)  timerEl.style.display = 'none';
    }
  }, 1000);

  /* Auto-close after 30s if player ignores it */
  _interTimer = setTimeout(function() { _interSkip(); }, 30000);
}

function _interSkip() {
  clearInterval(_interCountdown);
  clearTimeout(_interTimer);
  var ov = document.getElementById('inter-overlay');
  if (ov) ov.classList.remove('active');
  /* Brief fade before callback so the overlay disappears cleanly */
  setTimeout(function() {
    if (_interCallback) { var cb = _interCallback; _interCallback = null; cb(); }
  }, 320);
}

/* ══════════════════════════════════════════════════════════════
   BACKGROUND MUSIC
   32-second loop — starts on first user interaction
   ══════════════════════════════════════════════════════════════ */
var musicOn = true;
var _bgmStarted = false;

function _bgmEl() { return document.getElementById('bgm-audio'); }

function bgmPlay() {
  var el = _bgmEl();
  if (!el || !musicOn) return;
  el.volume = 0.55;
  var promise = el.play();
  if (promise !== undefined) {
    promise.then(function() {
      _bgmStarted = true;  /* only mark started when play actually succeeds */
    }).catch(function() {
      _bgmStarted = false; /* reset so _firstTouch can retry on next gesture */
    });
  } else {
    _bgmStarted = true;    /* older browsers — no promise */
  }
}

function bgmPause() {
  var el = _bgmEl();
  if (el) el.pause();
}

function bgmResume() {
  var el = _bgmEl();
  if (el && musicOn && _bgmStarted) el.play().catch(function(){});
}

function bgmToggle() {
  musicOn = !musicOn;
  if (musicOn) { bgmResume(); }
  else          { bgmPause();  }
  var btn = document.getElementById('music-toggle');
  if (btn) btn.classList.toggle('on', musicOn);
  try { localStorage.setItem('bdw_music', musicOn ? '1' : '0'); } catch(e) {}
}

/* Load saved music preference — sync toggle direction on startup */
try {
  var _savedMusic = localStorage.getItem('bdw_music');
  if (_savedMusic === '0') { musicOn = false; }
} catch(e) {}
/* Sync toggle visual state with musicOn immediately */
document.addEventListener('DOMContentLoaded', function() {
  var mt = document.getElementById('music-toggle');
  if (mt) mt.classList.toggle('on', musicOn); /* ON=right+green  OFF=left+grey */
});

/* Start on first user interaction anywhere on page */
var _firstTouch = function() {
  document.removeEventListener('touchstart', _firstTouch);
  document.removeEventListener('click', _firstClick);
  setTimeout(bgmPlay, 0); /* defer so native touch handlers fire first */
};
var _firstClick = function() {
  document.removeEventListener('click', _firstClick);
  document.removeEventListener('touchstart', _firstTouch);
  setTimeout(bgmPlay, 0); /* defer so it never blocks the button's own handler */
};
document.addEventListener('touchstart', _firstTouch, { passive: true });
document.addEventListener('click', _firstClick);

/* ── Try autoplay immediately (works in native WebViews) ──── */
document.addEventListener('DOMContentLoaded', function() {
  var el = document.getElementById('bgm-audio');
  if (el && musicOn) {
    el.volume = 0.55;
    el.play().then(function() {
      _bgmStarted = true;
    }).catch(function() {
      /* browser blocked autoplay — gesture fallback will handle it */
    });
  }
});

/* ── Save on hard close (swipe-kill, battery death, crash) ── */
window.addEventListener('beforeunload', function() {
  try { Economy._save(); } catch(e) {}
  try { if (currentUser && currentUser.dataKey) saveUserData(currentUser.dataKey); } catch(e) {}
});

