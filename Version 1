function startGame(lid) {
  var lv = LEVELS.filter(function(l) { return l.id === lid; })[0];
  if (!lv || lv.id > G.maxUnlocked) return;
  /* Auto-refill: consume a banked Heart from Spin Wheel inventory if out of hearts */
  if(!canPlay() && typeof SPW!=='undefined' && (SPW._inv.heart||0)>0) {
    SPW.load();
    SPW._inv.heart--;
    SPW._save();
    Economy.addHearts(1);
    if(typeof storeToast==='function')
      storeToast('\u2764\uFE0F Spin reward heart used automatically!','rgba(39,174,96,.9)');
  }
  if (!canPlay()) { showNH(); return; }
  clearInterval(G._timer); clearTimeout(G._conTimer);
  G.level = lv;
  /* Milestone levels (×5): 1 specific theme meal
     Standard levels: lv.mealCount random standard meals */
  var q = (lv.mealCount <= 1)
    ? [lv.meal]
    : genQueue(lv.mealCount);
  G.mealQ = q; G.mealIdx = 0;
  G.mealStatus = q.map(function(_, i){ return i === 0 ? 'cur' : 'pend'; });
  G.recipe = REC[q[0]]; G.tiles = makeRound(G.recipe, lv.mystery);
  G.seqIdx = 0; G.usedBoxes = []; G.hearts = Economy.hearts; G.shields = Economy.shields; G.extraHearts = Economy.extraHearts || 0;
  G.score = 0; G.levelScore = 0; G.timeLeft = levelTime(lv.id);
  G.phase = 'playing'; G.mystRes = null; G.mistakes = 0;
  showScreen('gamescreen');
  if (_extraHeartPending) {
    _extraHeartPending = false;
    setTimeout(_showExtraHeartToast, 900);
  }
  try { renderGame(); } catch(e) {
    var _gs=document.getElementById('gamescreen');
    if(_gs) _gs.innerHTML='<div style="color:#fff;padding:20px;font-size:14px"><b>Error:</b> '+e.message+'</div>';
    console.error('renderGame:',e); return;
  }
  /* Tutorial intercepts timer start on L1 first-ever play */
  if (G.level.id === 1 && TUT.show()) {
    /* TUT._close() will restart timer when dismissed */
  } else if (G.level.id === 6 && MOLD_TUT.show()) {
    /* MOLD_TUT._close() will restart timer when dismissed */
  } else {
    G._timer = setInterval(tick, 1000);
  }
}

function tick() {
  if (G.phase !== 'playing') return;  /* also catches 'paused' */
  G.timeLeft--;
  if (G.timeLeft <= 5 && G.timeLeft > 0) SFX.tick();
  if (G.timeLeft <= 0) { clearInterval(G._timer); timeUp(); }
  else updateTimerDisplay();
}

function timeUp() {
  SFX.timeUp(); vib([100,50,100]);
  if (G.shields > 0) {
    shieldAbsorbHit();
    G.timeLeft = 5; G.phase = 'playing';
    G._timer = setInterval(tick, 1000);
    return;
  }
  var done=(G.mealStatus||[]).filter(function(s){return s==='done';}).length;
  if(done>0||G.seqIdx>2){clearInterval(G._timer);showOOT();}
  else{execTimeUp();}
}

function tapTile(key) {
  if (G.phase !== 'playing') return;
  var tile = null;
  for (var i = 0; i < G.tiles.length; i++) { if (G.tiles[i].key === key) { tile = G.tiles[i]; break; } }
  if (!tile) return;

  if (tile.type === 'mys') {
    if (G.usedBoxes.indexOf(key) >= 0) return;
    G.usedBoxes.push(key);
    SFX.mystery();
    if (G.seqIdx === 0) { showMyst('Nothing happened!', '#777'); renderGame(); return; }
    var roll = Math.random();
    if (roll < 0.35) {
      SFX.superBox();
      var ns = Math.min(G.seqIdx + 2, G.recipe.needs.length);
      var added = ns - G.seqIdx;
      G.score += added * PTS; G.seqIdx = ns;
      spawnPop('\u2b50 +' + (added * PTS), '#FFD700');
      showMyst('\u2b50 +' + added + ' ingredient' + (added !== 1 ? 's' : '') + '!', '#27AE60');
      if (G.seqIdx >= G.recipe.needs.length) advanceMeal(); else renderGame();
    } else if (roll < 0.65) {
      SFX.bonus();
      var bonus = G.level.id <= 5 ? 5 : 3;
      G.timeLeft += bonus;
      spawnPop('+' + bonus + 's \u23f1', '#5DADE2');
      showMyst('+' + bonus + ' seconds!', '#1858B0');
      renderGame();
    } else {
      SFX.anti();
      if (G.seqIdx > 0) { G.seqIdx--; G.score = Math.max(0, G.score - PTS); spawnPop('\uD83D\uDC80 -1', '#E74C3C'); }
      showMyst('Lost an ingredient!', '#981010');
      renderGame();
    }
    return;
  }

  var required = G.recipe.needs[G.seqIdx];
  if (tile.ingId === required) {
    SFX.correct(); vib(30);
    spawnPop('+10', '#7DCEA0');
    animTile(key, 'pop');
    /* Golden ingredient check — entire level perfect so far */
    var _wasGolden = (
      G.level && G.level.id >= 8 &&
      G.mistakes === 0 &&
      G.mealIdx === G.mealQ.length - 1 &&
      G.seqIdx === G.recipe.needs.length - 1
    );
    G.seqIdx++; G.score += PTS;
    if (G.seqIdx >= G.recipe.needs.length) {
      if (_wasGolden) showGoldenReward();
      advanceMeal();
    } else { renderGame(); }
  } else {
    SFX.wrong(); vib([70,30,70]);
    spawnPop('-\u2764\uFE0F', '#E74C3C');
    animTile(key, 'shake');
    spawnFlash();
    if (G.shields > 0) {
      shieldAbsorbHit();
    } else {
      G.mistakes++;              /* unshielded wrong tap — counts toward star rating */
      loseHeart();               /* deducts from Economy.hearts, starts refill timer */
      G.hearts = Economy.hearts; /* keep G.hearts in sync with Economy */
      if (G.hearts <= 0 && !hasUL()) {
        clearInterval(G._timer);
        G.phase = 'gameover';
        renderResult();
        showNH();
      } else { renderGame(); }
    }
  }
}

function advanceMeal() {
  var ni = G.mealIdx + 1;
  G.mealStatus[G.mealIdx] = 'done';
  if (ni >= G.mealQ.length) {
    clearInterval(G._timer);
    SFX.level();
    G.levelScore = G.score;
    G.hiScore     = Math.max(G.hiScore, G.score);
    G.maxUnlocked = Math.min(99, Math.max(G.maxUnlocked, (G.level.id || 0) + 1));
    /* Save stars — never downgrade a previous best */
    var earnedStars = calcStars(G.mistakes);
    G.levelStars[G.level.id] = Math.max(earnedStars, G.levelStars[G.level.id] || 0);
    saveProgress();   /* persist immediately after every level clear */
    updateWelcomeLvl(); /* refresh profile badge */
    /* Award player level if ≥1 star (serving all meals = win) */
    if (calcStars(G.mistakes) >= 1) { awardPlayerLevel(); }
    G.phase = 'complete';
    renderResult();
    _maybeShowRatePrompt(); /* Rate prompt — Level 5 first time only */
    /* L1 always gets +2500ms so the banner/fireworks finish before level select */
    var _advDelay = (G.level && G.level.id === 1) ? CONGRATS_MS + 2500 : CONGRATS_MS;
    G._conTimer = setTimeout(function() {
    _showInterstitialAd(function() {
      renderLevelSelect(); showScreen('levelselect');
    });
  }, _advDelay);
  } else {
    SFX.meal();
    spawnBurst(G.recipe.emoji, G.recipe.name);
    G.mealStatus[ni] = 'cur'; G.mealIdx = ni;
    G.recipe = REC[G.mealQ[ni]];
    G.tiles = makeRound(G.recipe, G.level.mystery);
    G.seqIdx = 0; G.usedBoxes = [];
    G.timeLeft = levelTime(G.level.id); /* fresh timer each meal */
    renderGame();
  }
}

function tryAgain() {
  clearInterval(G._timer); clearTimeout(G._conTimer);
  var q = genQueue(G.level.id);
  G.mealQ = q; G.mealIdx = 0;
  G.mealStatus = q.map(function(_, i) { return i === 0 ? 'cur' : 'pend'; });
  G.recipe = REC[q[0]]; G.tiles = makeRound(G.recipe, G.level.mystery);
  G.seqIdx = 0; G.usedBoxes = []; G.score = 0;
  G.timeLeft = levelTime(G.level.id); G.phase = 'playing'; G.mystRes = null;
  renderGame();
  G._timer = setInterval(tick, 1000);
}

function showMyst(text, bgColor) {
  G.mystRes = {text: text, bg: bgColor};
  clearTimeout(G._mystTimer);
  G._mystTimer = setTimeout(function() { G.mystRes = null; renderGame(); }, 1900);
}

