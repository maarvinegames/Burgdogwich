<style>
/* ── UNIVERSAL RESPONSIVE LAYOUT ─────────────────────────────── */
html{width:100%;height:100%;margin:0;padding:0}
body{width:100%;height:100%;margin:0;padding:0;
  overflow:hidden;background:#111;
  display:flex;justify-content:center;align-items:flex-start}
#app{position:relative;width:100%;max-width:430px;height:100%;
  overflow:hidden;font-family:'Trebuchet MS',Arial,sans-serif;color:#fff}

*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none;margin:0;padding:0}



/* SCREENS */
.screen{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .25s ease}
.screen.active{opacity:1;pointer-events:all}







/* WELCOME */
#welcome{background:#87CEEB}
#welcome .bg{position:absolute;inset:0;background:url("data:image/jpeg;base64,") center top/cover no-repeat;z-index:0}

/* SUN ANIMATION */
#sun-layer{position:absolute;top:0;left:0;width:170px;height:170px;z-index:1;pointer-events:none}
#sun-core{position:absolute;top:50%;left:50%;width:64px;height:64px;margin:-32px 0 0 -32px;border-radius:50%;background:radial-gradient(circle,#FFFDE7 0%,#FFE066 35%,#FFB300 65%,transparent 80%)}
@keyframes corePulse{0%,100%{transform:scale(1);opacity:.9}50%{transform:scale(1.18);opacity:1}}
#sun-core{animation:corePulse 2.4s ease-in-out infinite}
#sun-rays{display:none;/* new bg has built-in sun */position:absolute;inset:0}
@keyframes raySpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
#sun-rays{animation:raySpin 9s linear infinite}
.sun-ray{position:absolute;top:50%;left:50%;height:3px;border-radius:3px;background:linear-gradient(90deg,rgba(255,220,50,.85),rgba(255,220,50,0));transform-origin:0 50%}
@keyframes flare1{0%,100%{opacity:0;transform:translate(58px,55px) rotate(20deg) scaleX(.5)}45%{opacity:.75;transform:translate(78px,65px) rotate(20deg) scaleX(1)}}
@keyframes flare2{0%,100%{opacity:0;transform:translate(45px,70px) rotate(-10deg) scaleX(.4)}55%{opacity:.5;transform:translate(65px,85px) rotate(-10deg) scaleX(1)}}
