      +   '<path d="M42 17 Q54 5 64 9 Q54 15 42 18Z" fill="#111"/>'
      + '</g>'
      + '</svg>';
  }

  function spawnBird() {
    var welcome = document.getElementById('welcome');
    if (!welcome || !welcome.classList.contains('active')) return;

    var bird = document.createElement('div');
    bird.className = 'flying-bird';

    /* Random vertical position — upper 15-55% of screen */
    var yPct  = 15 + Math.random() * 40;
    /* Random size: 14-26px tall — smaller = farther away */
    var sz    = 14 + Math.floor(Math.random() * 13);
    /* Random speed: 5-10s to cross */
    var dur   = 5000 + Math.random() * 5000;
    /* Slight vertical drift during flight */
    var drift = (Math.random() > 0.5 ? 1 : -1) * (10 + Math.random() * 20);

    bird.style.cssText =
      'top:'  + yPct + '%;'
      + 'right:-120px;'
      + 'animation:birdCross ' + dur + 'ms linear forwards;';

    bird.innerHTML = makeBirdSVG(sz);
    welcome.appendChild(bird);

    /* Remove after flight */
    setTimeout(function() {
      if (bird.parentNode) bird.parentNode.removeChild(bird);
    }, dur + 400);
  }

  function scheduleBird() {
    /* Random gap 6-18 seconds between birds */
    var gap = 6000 + Math.random() * 12000;
    setTimeout(function() {
      spawnBird();
      /* Occasionally send a second bird shortly after (flock effect) */
      if (Math.random() < 0.35) {
        setTimeout(spawnBird, 800 + Math.random() * 1200);
      }
      scheduleBird();
    }, gap);
  }

  /* Start after welcome screen loads */
  setTimeout(function() {
    scheduleBird();
    /* Fire one immediately so player sees it on first load */
    setTimeout(spawnBird, 2500);
  }, 1000);
})();

