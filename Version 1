  position:fixed;bottom:-60px;left:50%;transform:translateX(-50%);
  background:rgba(220,40,40,.92);border-radius:30px;
  padding:9px 20px;font-size:12px;font-weight:700;color:#fff;
  z-index:15000;white-space:nowrap;
  transition:bottom .35s ease,opacity .35s ease;
  box-shadow:0 3px 14px rgba(0,0,0,.4)
}
#extra-heart-toast.show{bottom:28px}
#extra-heart-toast.hide{opacity:0}

