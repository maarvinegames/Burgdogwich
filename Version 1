/* ── Check existing consent on boot ── */
function _checkConsent(afterSplash) {
  try {
    var saved = JSON.parse(localStorage.getItem(_PP_KEY));
    if (saved && saved.v === 2) {
      isChild = !!saved.isChild;
      _configureAds(isChild);
