/* ═══════════════════════════════════════════
   PROGRESS PERSISTENCE — maxUnlocked + hiScore
   Key: bdw_progress_v1
   Saves per device; also merged into user account
   data when a user is logged in.
═══════════════════════════════════════════ */
var _PROG_KEY = 'bdw_progress_v1';

function saveProgress() {
  savePLvl(); /* save player level */
  try {
    var payload = { maxUnlocked: G.maxUnlocked, hiScore: G.hiScore, levelStars: G.levelStars };
    localStorage.setItem(_PROG_KEY, JSON.stringify(payload));
    /* Also write into logged-in user's account slot */
    if (currentUser && currentUser.dataKey) {
      try {
        var ud = JSON.parse(localStorage.getItem('bdw_ud_' + currentUser.dataKey) || 'null') || {};
        ud.maxUnlocked = G.maxUnlocked;
        ud.hiScore     = G.hiScore;
        ud.levelStars  = G.levelStars;
        localStorage.setItem('bdw_ud_' + currentUser.dataKey, JSON.stringify(ud));
      } catch(e) {}
    }
  } catch(e) {}
}

function loadProgress() {
  loadPLvl(); /* load player level */
  /* Prefer user-account data, fall back to device-global save */
  var loaded = false;
  if (currentUser && currentUser.dataKey) {
    try {
      var ud = JSON.parse(localStorage.getItem('bdw_ud_' + currentUser.dataKey) || 'null');
      if (ud && ud.maxUnlocked) {
        G.maxUnlocked = ud.maxUnlocked || 1;
        G.hiScore     = ud.hiScore     || 0;
        if (ud.levelStars) Object.assign(G.levelStars, ud.levelStars);
        loaded = true;
      }
    } catch(e) {}
  }
  if (!loaded) {
    try {
      var d = JSON.parse(localStorage.getItem(_PROG_KEY) || 'null');
      if (d) {
        G.maxUnlocked = d.maxUnlocked || 1;
        G.hiScore     = d.hiScore     || 0;
        if (d.levelStars) Object.assign(G.levelStars, d.levelStars);
      }
    } catch(e) {}
  }
}

