var isChild  = false;   /* true = under 13, use contextual ads only */
var _PP_KEY  = 'bdw_pp_v2';
try{localStorage.removeItem('bdw_pp_v1');}catch(e){} /* clean up old key */

/* ── Age Gate ── */
function agGateCheck() {
  var yr   = parseInt(document.getElementById('ag-year').value, 10);
  var btn  = document.getElementById('ag-continue');
  if (!yr || isNaN(yr)) { btn.classList.remove('ready'); return; }
  btn.classList.add('ready');
}

function agGateProceed() {
  var yr  = parseInt(document.getElementById('ag-year').value, 10);
  if (!yr || isNaN(yr)) return;
  var age = new Date().getFullYear() - yr;
  isChild = (age < 13);            /* COPPA threshold */
  var isMinor = (age < 18);

  /* If child (<13) skip privacy modal and go straight to game with COPPA flag */
  if (isChild) {
    localStorage.setItem(_PP_KEY, JSON.stringify({v:2,isChild:true,ts:Date.now()}));
    _launchGame();
    return;
  }

  /* Adults / teens → show privacy policy */
  /* Always reset checkboxes to unchecked when modal opens */
  _ppState[1] = false; _ppState[2] = false;
  var c1=document.getElementById('pp-chk1'), c2=document.getElementById('pp-chk2');
  if(c1){c1.classList.remove('checked');c1.innerHTML='';}
  if(c2){c2.classList.remove('checked');c2.innerHTML='';}
  var cfm=document.getElementById('pp-confirm');
  if(cfm)cfm.classList.remove('ready');
  document.getElementById('privacy-modal').classList.add('open');
  /* Both checkboxes must always be manually checked */
  _ppState[1] = false; _ppState[2] = false;
}

/* ── Privacy Policy Checkboxes ── */
var _ppState = {1: false, 2: false};

function ppToggle(n, forceOn) {
  _ppState[n] = (forceOn === true) ? true : !_ppState[n];
  var el = document.getElementById('pp-chk' + n);
  if (el) {
    el.classList.toggle('checked', _ppState[n]);
    el.innerHTML = _ppState[n] ? '<span style="color:#fff;font-size:18px;font-weight:900;line-height:1">&#10003;</span>' : '';
  }
  /* Enable CONFIRM only when BOTH boxes checked */
  var btn = document.getElementById('pp-confirm');
  if (btn) {
    var allChecked = _ppState[1] && _ppState[2];
    btn.classList.toggle('ready', allChecked);
  }
}

function ppConfirm() {
  if (!_ppState[1] || !_ppState[2]) return;
  localStorage.setItem(_PP_KEY, JSON.stringify({v:2,isChild:false,ts:Date.now()}));
  document.getElementById('privacy-modal').classList.remove('open');
  bgmPlay(); /* user just tapped CONFIRM — gesture is live, start music now */
  _launchGame();
}

