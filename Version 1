.oot-give{width:100%;padding:11px;background:transparent;border:1px solid rgba(255,255,255,.2);border-radius:12px;color:rgba(255,255,255,.4);font-size:13px;cursor:pointer;font-family:inherit}
.coin-chip{background:rgba(0,0,0,.45);border:1px solid rgba(255,215,0,.35);border-radius:8px;padding:2px 6px;font-size:10px;font-weight:700;color:#FFD700;display:flex;align-items:center;gap:3px;flex-shrink:0}
/* howto panel */
.howto-panel{background:rgba(0,0,0,.28);border-radius:12px;padding:12px;margin-top:10px;display:none}
.howto-panel.open{display:block}
.howto-text{font-size:12.5px;line-height:1.7;color:rgba(255,255,255,.92)}
.modal-close{margin-top:16px;width:100%;padding:11px;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.35);border-radius:12px;color:#fff;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit}
.setting-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid rgba(255,255,255,.18)}
.setting-label{font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px}
/* AUTH SCREEN */
#auth-screen{position:absolute;inset:0;background:linear-gradient(155deg,#1A0800,#3A1000,#1A0800);z-index:600;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;opacity:0;pointer-events:none;transition:opacity .3s}
#auth-screen.open{opacity:1;pointer-events:all}
.auth-logo-title{font-family:'Arial Black',Arial,sans-serif;font-size:24px;color:#FFE566;margin:0 0 3px}
.auth-logo-sub{font-size:12px;color:rgba(255,207,139,.5);margin:0 0 22px;letter-spacing:1px}
.auth-tabs{display:flex;gap:0;background:rgba(0,0,0,.35);border-radius:10px;padding:3px;margin-bottom:16px}
.auth-tab{padding:8px 28px;border:none;border-radius:8px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;background:transparent;color:rgba(255,207,139,.5);transition:all .2s}
.auth-tab.active-tab{background:linear-gradient(135deg,#FF8C00,#D43010);color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.3)}
.auth-card{background:rgba(0,0,0,.45);border:1px solid rgba(255,140,0,.3);border-radius:18px;padding:20px 18px;width:100%;max-width:320px}
.auth-input{width:100%;padding:12px 14px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:10px;color:#fff;font-size:14px;font-family:inherit;margin-bottom:10px;box-sizing:border-box;outline:none}
.auth-input:focus{border-color:rgba(255,140,0,.6)}
.auth-input::placeholder{color:rgba(255,255,255,.3)}
.auth-error{color:#FF8080;font-size:12px;min-height:16px;margin-bottom:10px;text-align:center}
.auth-submit{touch-action:manipulation;width:100%;padding:13px;background:linear-gradient(135deg,#FFD700,#FF8C00);border:none;border-radius:12px;color:#3A1800;font-size:15px;font-weight:900;cursor:pointer;font-family:inherit}
.auth-guest-btn{margin-top:12px;background:none;border:none;color:rgba(255,207,139,.55);font-size:13px;cursor:pointer;text-decoration:underline;font-family:inherit;padding:4px 8px}
/* SHIELD */
.shield-hud{display:flex;align-items:center;gap:3px;background:rgba(0,0,0,.35);border-radius:8px;padding:3px 8px;margin-left:10px;transition:opacity .3s}
.shield-hud.empty{opacity:0.4}
.shield-count{font-size:13px;font-weight:700;color:#5DADE2}
@keyframes shieldFlash{0%{opacity:.75}100%{opacity:0}}
/* GUEST WARNING */
#guest-warning{background:rgba(255,140,0,.12);border:1px solid rgba(255,140,0,.35);border-radius:10px;padding:10px 12px;margin-bottom:12px;text-align:left}
.gw-title{font-weight:700;color:#FFE566;font-size:12px;margin-bottom:4px}
.gw-.gw-body{color:rgba(255,207,139,.75);font-size:11px;line-height:1.5}
.gw-btn{width:100%;margin-top:8px;padding:9px;background:linear-gradient(135deg,#FFD700,#FF8C00);border:none;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;font-family:inherit;color:#3A1800}
.bo.coin-heart{background:linear-gradient(135deg,#C8960C,#A0780A);color:#fff;border:2px solid rgba(255,215,0,.4)}
.bo.coin-heart:disabled{opacity:.4;cursor:default}

/* ─── BOOSTER ROW ─────────────────────────────────────────── */
.booster-row{display:flex;justify-content:center;gap:14px;padding:7px 11px;
background:rgba(0,0,0,.35);border-top:1px solid rgba(255,140,0,.15);flex-shrink:0}
.booster-slot{position:relative;width:44px;height:44px;border-radius:50%;
background:linear-gradient(135deg,#2D3748,#1A202C);
border:2px solid rgba(255,140,0,.5);display:flex;flex-direction:column;
align-items:center;justify-content:center;cursor:pointer;
transition:transform .1s,box-shadow .1s;user-select:none}
.booster-slot:active:not(.locked){transform:scale(.9)}
.booster-slot.locked{filter:grayscale(1) opacity(.45);cursor:default;
border-color:rgba(255,255,255,.12)}
.booster-icon{font-size:16px;line-height:1}
.booster-lbl{font-size:7px;color:rgba(255,255,255,.6);font-weight:700;
letter-spacing:.3px;margin-top:1px;text-align:center}
.booster-badge{position:absolute;top:-6px;right:-6px;background:#E53E3E;
color:#fff;font-size:9px;font-weight:900;min-width:20px;height:20px;padding:0 3px;
border-radius:50%;display:flex;align-items:center;justify-content:center;
border:2px solid #fff;line-height:1}
.booster-lock{position:absolute;top:-4px;right:-4px;font-size:13px}
/* ─── BOSS LEVEL BANNER ────────────────────────────────────── */
.boss-banner{text-align:center;padding:5px;
background:linear-gradient(135deg,#C62828,#B71C1C);
color:#FFD700;font-weight:900;font-size:12px;letter-spacing:1.5px;
flex-shrink:0;text-shadow:0 1px 3px rgba(0,0,0,.5)}

/* SPIN WHEEL MODAL */
#spin-modal{position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:9000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .35s}
#spin-modal.open{opacity:1;pointer-events:all}
.spw-wrap{width:min(95%,400px);background:linear-gradient(155deg,#1C0800,#2C1200,#3A1800);border:3px solid rgba(255,165,0,.5);border-radius:20px;padding:12px 12px 14px;display:flex;flex-direction:column;gap:6px;box-shadow:0 0 50px rgba(255,120,0,.28);max-height:94vh;overflow:hidden}
.spw-hdr{display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,140,0,.22);padding-bottom:8px}
.spw-back{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);color:#fff;border-radius:8px;padding:5px 10px;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit}
.spw-title{flex:1;text-align:center;font-size:14px;font-weight:900;color:#FFD700;font-family:'Arial Black',sans-serif;letter-spacing:.5px}
.spw-body{display:flex;gap:7px;align-items:flex-start;padding:4px 0}
.spw-sb{width:min(116px,28vw);flex-shrink:0;display:flex;flex-direction:column;gap:2px;align-self:stretch}
.spw-sb-hd{font-size:8px;font-weight:700;color:rgba(255,165,0,.65);letter-spacing:1.5px;text-align:center;margin-bottom:2px}
.spw-inv{display:flex;align-items:center;gap:4px;background:rgba(0,0,0,.45);border:1px solid rgba(255,140,0,.18);border-radius:7px;padding:4px 6px;transition:all .3s}
.spw-inv.spw-glow{border-color:#FFD700;box-shadow:0 0 12px rgba(255,215,0,.6);animation:spwPulse .5s ease-in-out 4}
.spw-i-em{font-size:16px;line-height:1;flex-shrink:0}
.spw-i-nm{font-size:8px;font-weight:700;color:rgba(255,255,255,.7);line-height:1.15;flex:1}
.spw-i-ct{font-size:13px;font-weight:900;color:#FFE566;min-width:18px;text-align:right}
.spw-wheel-area{flex:1;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;gap:1px}
.spw-ptr{width:0;height:0;border-left:11px solid transparent;border-right:11px solid transparent;border-top:22px solid #FF3D00;filter:drop-shadow(0 2px 5px rgba(0,0,0,.7));z-index:2}
#spw-canvas{width:min(220px,100%);height:min(220px,100%);display:block;margin:0 auto}
.spw-fly{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.75);color:#FFD700;font-size:18px;font-weight:800;padding:6px 14px;border-radius:20px;white-space:nowrap;transition:opacity .6s;opacity:0;pointer-events:none;z-index:5}
.spw-foot{display:flex;flex-direction:column;align-items:center;gap:6px;border-top:1px solid rgba(255,140,0,.22);padding-top:8px}
.spw-reward{display:none;background:rgba(39,174,96,.2);border:2px solid #27AE60;border-radius:10px;padding:7px 14px;color:#7DCEA0;font-weight:700;font-size:12px;text-align:center;width:92%;animation:spwFadeIn .4s ease}
.spw-reward.show{display:block}
.spw-btn{touch-action:manipulation;padding:min(11px,2.8vw);background:linear-gradient(180deg,#4CAF50,#2E7D32);border:2px solid #FFD700;border-radius:50px;color:#fff;font-size:clamp(12px,3.5vw,15px);font-weight:900;letter-spacing:1px;cursor:pointer;font-family:'Arial Black',Arial,sans-serif;box-shadow:0 5px 0 #7B0000,0 7px 16px rgba(200,0,0,.4);transition:transform .1s,box-shadow .1s;animation:btnPulse 1.8s ease-in-out infinite}
.spw-btn:active:not(:disabled){transform:translateY(4px);box-shadow:0 1px 0 #7B0000;animation:none}
.spw-btn:disabled{background:linear-gradient(180deg,#444,#222);box-shadow:none;animation:none;cursor:default;color:rgba(255,255,255,.35)}

/* ── Two-button row in spin wheel footer ──────────────────── */
.spw-btn-row{display:flex;gap:8px;width:92%;margin:0 auto}
.spw-btn-half{flex:1;min-width:0}
.spw-btn-ad{flex:1;min-width:0;
  padding:min(11px,2.8vw);
  background:linear-gradient(180deg,#E65C00,#B34400);
  border:2px solid #FFD700;border-radius:50px;
  color:#fff;font-size:clamp(12px,3.5vw,15px);font-weight:900;
  font-family:'Arial Black',Arial,sans-serif;cursor:pointer;
  box-shadow:0 3px 0 #7A2E00;
  transition:transform .1s,box-shadow .1s,opacity .2s;
  letter-spacing:1px}
.spw-btn-ad:disabled{opacity:.45;cursor:default;
  background:linear-gradient(180deg,#888,#555);
  border-color:rgba(255,255,255,.2);
  box-shadow:0 2px 0 #333}
.spw-btn-ad:active:not(:disabled){transform:translateY(3px);box-shadow:0 0 0 #7A2E00}

.spw-info{font-size:10px;color:rgba(255,207,139,.6);font-weight:700;text-align:center}
.spw-again{display:none;gap:7px;justify-content:center}
.spw-again.show{display:flex}
.spw-again-btn{padding:6px 12px;border-radius:9px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid rgba(255,165,0,.38);color:#FFD700;background:rgba(255,165,0,.1);font-family:inherit}
.spw-gameover-btn{width:100%;padding:12px;background:linear-gradient(135deg,#F44336,#B71C1C);border:none;border-radius:12px;color:#fff;font-size:14px;font-weight:900;cursor:pointer;font-family:inherit;margin-bottom:7px;box-shadow:0 4px 0 #7B0000;animation:btnPulse 1.8s ease-in-out infinite}
@keyframes spwPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
@keyframes spwFadeIn{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}

/* HOME SPIN BUTTON */
#spin-home-btn{background:linear-gradient(180deg,#E83020,#D43010);
  box-shadow:0 6px 0 #7A1800,0 8px 16px rgba(212,48,16,.45),inset 0 1px 0 rgba(255,255,255,.2)}
#spin-home-btn.free-glow{
  background:linear-gradient(180deg,#FF4020,#D43010);
  box-shadow:0 6px 0 #7A1800,0 8px 16px rgba(212,48,16,.55),inset 0 1px 0 rgba(255,255,255,.35)}
#spin-home-btn:active{transform:translateY(4px);box-shadow:0 2px 0 #7A1800}
#spin-home-badge{font-size:8px;font-weight:700;letter-spacing:.5px;
  text-align:center;margin-top:2px;min-height:10px}

/* ── FIREWORK PARTICLES ──────────────────────────────────────── */
#fw-layer{position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:1}
.fw-p{position:absolute;border-radius:50%;opacity:1;animation:fwRise linear forwards}
@keyframes fwRise{
  0%  {transform:translateY(0) scale(1);opacity:1}
  70% {opacity:1}
  100%{transform:translateY(-420px) scale(0);opacity:0}
}
/* ── LEVEL 1 BANNER ─────────────────────────────────────────── */
#l1-banner{
  position:absolute;top:18px;left:50%;transform:translateX(-50%) translateY(-100px);
  background:linear-gradient(135deg,#FFD700,#FF8C00);
  color:#1A0400;font-weight:900;font-size:clamp(11px,3.2vw,14px);
  padding:9px 14px;border-radius:14px;text-align:center;
  width:76%;max-width:280px;
  white-space:normal;word-break:break-word;line-height:1.35;
  z-index:20;box-shadow:0 6px 24px rgba(0,0,0,.5);
  opacity:0;
  animation:bannerIn .5s cubic-bezier(.34,1.56,.64,1) .1s forwards,
            bannerOut .4s 2.2s ease-in forwards
}
@keyframes bannerIn{
  to{transform:translateX(-50%) translateY(0);opacity:1}
}
@keyframes bannerOut{
  to{opacity:0;transform:translateX(-50%) translateY(-20px)}
}
/* ── SPECIAL LEVEL CARD (gold) ───────────────────────────────── */
.lvl-card.special{
  border:2px solid #FFD700;
  background:rgba(255,215,0,.12);
  box-shadow:0 0 12px rgba(255,215,0,.25)
}
.lvl-card.special .lvl-num{color:#FFD700!important}
.lvl-badge{
  font-size:9px;font-weight:900;color:#1A0400;
  background:#FFD700;border-radius:6px;
  padding:1px 5px;letter-spacing:.4px;margin-left:4px;
  display:inline-block;vertical-align:middle
}

/* ── FIRST-TIME TUTORIAL ─────────────────────────────────────── */
#tut-overlay{
  position:fixed;inset:0;z-index:980;
  background:rgba(0,0,0,.82);
  display:flex;flex-direction:column;
  align-items:center;justify-content:flex-end;
  padding-bottom:28px;animation:tutFadeIn .35s ease
}
@keyframes tutFadeIn{from{opacity:0}to{opacity:1}}
/* Chef Henry character */
.tut-henry-wrap{
  width:100%;max-width:340px;
  display:flex;justify-content:flex-end;
  padding-right:18px;margin-bottom:-18px;z-index:2;position:relative
}
.tut-henry-img{
  height:160px;width:auto;
  display:block;
  filter:drop-shadow(0 4px 12px rgba(0,0,0,.6));
  animation:tutHenryBob 2.4s ease-in-out infinite
}
@keyframes tutHenryBob{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-7px)}
}
/* Speech bubble card */
.tut-card{
  background:linear-gradient(160deg,#1A0E00,#2C1A00);
  border:2px solid #FFD700;border-radius:20px;
  padding:18px 22px 20px;max-width:340px;width:100%;
  text-align:left;position:relative;
  box-shadow:0 8px 32px rgba(0,0,0,.6),0 0 0 1px rgba(255,215,0,.15)
}
/* Speech bubble tail pointing right-upward toward Henry */
.tut-card::before{
  content:'';position:absolute;top:-12px;right:44px;
  border:12px solid transparent;
  border-bottom-color:#FFD700
}
.tut-card::after{
  content:'';position:absolute;top:-9px;right:46px;
  border:10px solid transparent;
  border-bottom-color:#2C1A00
}
.tut-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.tut-henry-name{
  font-size:13px;font-weight:900;color:#FFD700;
  letter-spacing:.5px
}
.tut-step-dots{display:flex;gap:6px;margin-left:auto}
.tut-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,215,0,.25);transition:background .3s}
.tut-dot.active{background:#FFD700}
.tut-msg{
  font-size:14px;color:rgba(255,255,255,.9);
  line-height:1.55;margin-bottom:14px
}
.tut-footer{display:flex;align-items:center;justify-content:space-between}
.tut-next-btn{
  background:linear-gradient(180deg,#FFD700,#E67E22);
  color:#1A0800;font-weight:900;font-size:14px;
  border:none;border-radius:12px;padding:10px 22px;
  cursor:pointer;
  box-shadow:0 4px 0 #8B4500
}
.tut-next-btn:active{transform:translateY(2px);box-shadow:0 2px 0 #8B4500}
#tut-skip{
  background:none;border:none;
  color:rgba(255,255,255,.35);font-size:12px;
  cursor:pointer;padding:4px 8px
}
#tut-skip:hover{color:rgba(255,255,255,.6)}
/* ── FIRST TILE PULSE (Option C) ─────────────────────────────── */
@keyframes tutPulse{
  0%,100%{box-shadow:0 0 0 0 rgba(255,215,0,.7),inset 0 0 0 3px rgba(255,215,0,.3)}
  50%{box-shadow:0 0 0 10px rgba(255,215,0,0),inset 0 0 0 3px rgba(255,215,0,.6)}
}
.tut-pulse{animation:tutPulse .75s ease-in-out 4!important}

/* Tutorial step arrow pointer */
.tut-arrow-wrap{
  width:100%;max-width:340px;
  display:flex;flex-direction:column;
  align-items:center;margin-bottom:4px
}
.tut-arrow-label{
  font-size:11px;font-weight:700;color:#FFD700;
  letter-spacing:.6px;margin-bottom:2px;text-transform:uppercase
}
.tut-arrow{
  font-size:36px;line-height:1;
  animation:tutArrowPulse .65s ease-in-out infinite
}
@keyframes tutArrowPulse{
  0%,100%{transform:translateY(0) scale(1);opacity:1}
  50%{transform:translateY(-8px) scale(1.1);opacity:.7}
}


/* ── PROFILE SCREEN ENHANCEMENTS ────────────────────────────── */
/* Bigger avatar square */
.prof-av{width:88px!important;height:88px!important;border-radius:14px!important;
  font-size:58px!important;cursor:pointer;
  transition:transform .15s;position:relative}
.prof-av:active{transform:scale(.95)}
.prof-av-hint{font-size:9px;color:rgba(255,255,255,.4);
  text-align:center;margin-top:-8px;margin-bottom:8px;letter-spacing:.3px}
/* Level badge — matches welcome screen gold pill */
.prof-lvl-badge{
  display:inline-block;background:linear-gradient(135deg,#FFD700,#FF8C00);
  color:#1A0400;font-size:10px;font-weight:900;
  border-radius:20px;padding:2px 10px;letter-spacing:.4px;
  box-shadow:0 2px 6px rgba(0,0,0,.3);margin-right:4px
}
/* Emoji picker panel */
.av-picker{
  background:rgba(0,0,0,.65);border:1px solid rgba(255,215,0,.3);
  border-radius:14px;padding:10px 12px;margin:4px 0 10px;
  display:none
}
.av-picker.open{display:block}
.av-picker-row{display:flex;gap:6px;flex-wrap:wrap;
  justify-content:center;margin-bottom:6px}
.av-opt{font-size:26px;cursor:pointer;padding:3px;border-radius:8px;
  border:2px solid transparent;transition:border-color .15s,transform .1s;
  line-height:1}
.av-opt:hover{border-color:#FFD700;transform:scale(1.15)}
.av-opt.selected{border-color:#FFD700;background:rgba(255,215,0,.15)}
.av-picker-label{font-size:9px;font-weight:700;color:rgba(255,215,0,.6);
  letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px}
.av-bg-swatch{width:26px;height:26px;border-radius:6px;cursor:pointer;
  border:2px solid transparent;transition:border-color .15s,transform .1s}
.av-bg-swatch:hover,.av-bg-swatch.selected{
  border-color:#FFD700;transform:scale(1.15)}

#prof-hbox, #prof-chef-since, #guest-warning {
  transition: opacity .25s ease;
}

/* ── FLYING BIRD ─────────────────────────────────────────────── */
.flying-bird{
  position:absolute;pointer-events:none;
  z-index:4; /* above background, below title + buttons */
  will-change:transform
}
@keyframes birdCross{
  0%  { transform:translateX(0) }
  100%{ transform:translateX(calc(-100vw - 120px)) }
}
/* Wing flap using CSS on two halves of the SVG */
.bird-wing-l{ transform-origin:right center;
  animation:flapL .45s ease-in-out infinite alternate }
.bird-wing-r{ transform-origin:left center;
  animation:flapR .45s ease-in-out infinite alternate }
@keyframes flapL{
  from{ transform:rotate(-15deg) }
  to  { transform:rotate(20deg)  }
}
@keyframes flapR{
  from{ transform:rotate(15deg)  }
  to  { transform:rotate(-20deg) }
}

/* ── MOLD MECHANIC ───────────────────────────────────────────── */
.mold-dot{
  position:absolute;top:4px;right:4px;
  width:9px;height:9px;border-radius:50%;
  background:#27AE60;border:1.5px solid #1A5C1A;
  box-shadow:0 0 5px rgba(39,174,96,.9),0 0 10px rgba(39,174,96,.5);
  animation:moldPulse 1.2s ease-in-out infinite;
  z-index:5;pointer-events:none
}
@keyframes moldPulse{
  0%,100%{box-shadow:0 0 4px rgba(39,174,96,.7),0 0 8px rgba(39,174,96,.3)}
  50%   {box-shadow:0 0 10px rgba(39,174,96,1),0 0 20px rgba(39,174,96,.7)}
}
.tile{position:relative}
@keyframes screenShake{
  0%,100%{transform:translateX(0)}
  20%{transform:translateX(-7px)}
