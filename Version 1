/* ══════════════════════════════════════════════════════════════
   PLAYER LEVEL SYSTEM
   Separate from map progression. +1 on any successful win (≥1★).
   Milestone every 10 levels: +1 extraHeart + 100 coins.
   ══════════════════════════════════════════════════════════════ */
var playerLevel    = 1;
var _PLVL_KEY      = 'bdw_plvl_v1';
var _extraHeartPending = false; /* show toast on next game start */

function savePLvl() {
  try { localStorage.setItem(_PLVL_KEY, playerLevel); } catch(e) {}
}

function loadPLvl() {
  try {
    var v = parseInt(localStorage.getItem(_PLVL_KEY), 10);
    if (v && v >= 1) playerLevel = Math.min(9999, v);
  } catch(e) {}
}

function awardPlayerLevel() {
  /* Only called when calcStars(G.mistakes) >= 1 */
  if (playerLevel >= 9999) return;
  playerLevel = Math.min(9999, playerLevel + 1);
  savePLvl();
  updateWelcomeLvl();  /* refresh welcome badge */
  updatePM();          /* refresh profile badge */

  /* Milestone every 10 levels */
  if (playerLevel % 10 === 0) {
    /* Give rewards */
    Economy.extraHearts = (Economy.extraHearts || 0) + 1;
    Economy.addCoins(100);
    Economy._save();
    Economy._ui();
    _extraHeartPending = true; /* show toast next game */

    /* Sparkle the badge */
    _sparkleBadge();

    /* Show milestone popup */
    _showMilestonePop(playerLevel);
  }
}

/* ── Badge sparkle ──────────────────────────────────────────── */
function _sparkleBadge() {
  /* Pulse both badge elements */
  ['welcome-lvl', 'prof-lvl-badge'].forEach(function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.style.animation = 'none';
    void el.offsetWidth;
    el.style.animation = 'lvlPulse .6s ease forwards';
    setTimeout(function() { el.style.animation = ''; }, 700);

    /* Spawn white sparkles around the badge */
    var rect = el.getBoundingClientRect();
    var cx = rect.left + rect.width / 2;
    var cy = rect.top  + rect.height / 2;
    for (var i = 0; i < 8; i++) {
      (function(idx) {
        setTimeout(function() {
          var sp = document.createElement('div');
          sp.className = 'lvl-spark';
          var angle = (idx / 8) * Math.PI * 2;
          var dist  = 28 + Math.random() * 18;
          sp.style.setProperty('--sx', (Math.cos(angle) * dist) + 'px');
          sp.style.setProperty('--sy', (Math.sin(angle) * dist) + 'px');
          sp.style.left = (cx - 6) + 'px';
          sp.style.top  = (cy - 6) + 'px';
          sp.textContent = '✨';
          document.body.appendChild(sp);
          setTimeout(function() { if (sp.parentNode) sp.parentNode.removeChild(sp); }, 950);
        }, idx * 60);
      })(i);
    }
  });
}

/* ── Milestone popup ────────────────────────────────────────── */
function _showMilestonePop(lvl) {
  var pop   = document.getElementById('plvl-popup');
  var title = document.getElementById('plvl-pop-title');
  if (!pop) return;
  if (title) title.textContent = '✨ Player Level ' + lvl + '!';
  pop.classList.remove('hide');
  pop.classList.add('show');
  setTimeout(function() {
    pop.classList.add('hide');
    setTimeout(function() { pop.classList.remove('show','hide'); }, 400);
  }, 2800);
}

